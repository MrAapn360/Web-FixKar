# Copy to ".env" and adjust. CRA reads REACT_APP_* vars at build/start time.

# Phase 1: keep the mock API on (frontend runs with fake data, no backend needed).
REACT_APP_USE_MOCK=true

# Phase 4+: point at the Laravel backend and set REACT_APP_USE_MOCK=false
REACT_APP_API_URL=http://localhost:8000/api
